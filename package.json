{
  "name": "ai-caddie",
  "version": "1.0.0",
  "private": true,
  "description": "AI Caddie — a golf shot-planning and performance web app: 3D course mapping, dispersion analysis, strokes-gained skill profiles, and short-game preparation.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "serve": "vite preview --host --port 4173",
    "start": "node server/index.js",
    "lint": "node scripts/check-structure.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
